# Vite environment variables — prefix with VITE_ to expose to the browser
# Copy this to .env and fill in your values.

# Backend API
VITE_API_BASE_URL=http://localhost:5000/api

# Firebase Client Config (public keys — safe to expose in frontend)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase VAPID Key — Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
